# ─────────────────────────────────────────────────────────────────────────────
# .env.example  —  copy to .env and fill in your values
#                  NEVER commit the filled-in .env to source control
# ─────────────────────────────────────────────────────────────────────────────


# ── DeceptivGuard auth ────────────────────────────────────────────────────────
# Clients must send this in the X-API-Key header.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
GUARDRAIL_API_KEY=replace-me-with-a-strong-random-key

# Separate credential for session inspection/deletion (GET/DELETE /session/{id}).
# If not set, falls back to GUARDRAIL_API_KEY.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
ADMIN_API_KEY=replace-me-with-a-different-random-key

# HMAC secret used to derive server-controlled session IDs.
# Prevents callers from rotating X-Session-Id to evade risk score accumulation.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=replace-me-with-another-random-key


# ── LLM Provider ─────────────────────────────────────────────────────────────
# Pick ONE: anthropic | digitalocean | generic
# Leave blank to run in echo/test mode (no LLM forwarding).
LLM_PROVIDER=anthropic

# Default model sent to the LLM if the request does not specify one.
# Anthropic:     claude-sonnet-4-20250514
# DigitalOcean:  llama3-70b-instruct  (or whichever model your DO agent exposes)
# Generic:       gpt-4o
LLM_MODEL=claude-sonnet-4-20250514


# ── Anthropic (LLM_PROVIDER=anthropic) ───────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...


# ── DigitalOcean GenAI (LLM_PROVIDER=digitalocean) ───────────────────────────
# DO_API_KEY      → your DigitalOcean personal access token
# DO_ENDPOINT_URL → base agent URL from the DO GenAI console
#                   The client appends /api/v1/chat/completions automatically.
#                   Format: https://<agent-id>.agents.do-ai.run
#
# Where to find DO_ENDPOINT_URL:
#   1. cloud.digitalocean.com → AI & ML → GenAI Platform
#   2. Open your Agent deployment → "API" tab
#   3. Copy the base URL (everything before /api/v1/...)
DO_API_KEY=dop_v1_...
DO_ENDPOINT_URL=https://<your-agent-id>.agents.do-ai.run


# ── Generic OpenAI-compatible endpoint (LLM_PROVIDER=generic) ────────────────
# Works with Ollama, vLLM, LM Studio, Together AI, Groq, Azure OpenAI, etc.
#
# Ollama (local, no auth):
#   GENERIC_ENDPOINT_URL=http://localhost:11434/v1
#   GENERIC_API_KEY=ollama
#   GENERIC_AUTH_PREFIX=
#
# Azure OpenAI:
#   GENERIC_ENDPOINT_URL=https://<resource>.openai.azure.com/openai/deployments/<deploy>/
#   GENERIC_API_KEY=<azure-key>
#   GENERIC_AUTH_HEADER=api-key
#   GENERIC_AUTH_PREFIX=
GENERIC_ENDPOINT_URL=
GENERIC_API_KEY=
GENERIC_AUTH_HEADER=Authorization
GENERIC_AUTH_PREFIX=Bearer 


# ── Session store ─────────────────────────────────────────────────────────────
# Leave blank for in-memory (scores lost on restart).
# Example: redis://localhost:6379/0
REDIS_URL=

# Flush sessions on startup.
# Useful when redeploying after a test run that left stale session history in
# Redis (e.g. old fabricated values from prior planning-LLM calls recycling
# back into [PRIOR FABRICATED CONTEXT]).
#
#   all              — delete every session in the store on startup
#   id1,id2,id3      — delete only the listed session IDs
#   (empty / unset)  — do nothing (default)
#
# The flush happens once at server startup and is logged.  Remove or empty this
# value after the first restart so subsequent restarts do not wipe live sessions.
FLUSH_SESSIONS_ON_STARTUP=


# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated allowed origins. Dev defaults to localhost if blank.
# Example: https://app.example.com,https://admin.example.com
ALLOWED_ORIGINS=


# ── Deception mode ────────────────────────────────────────────────────────────
# template   (default) — uses category-specific static prompt addenda
# generative           — query-aware, four-stage deception pipeline; significantly
#                        more convincing but uses two LLM calls per DECEIVE action
DECEPTION_MODE=template

# ── Generative mode: two-stage planning ───────────────────────────────────────
# Only applies when DECEPTION_MODE=generative.
# When enabled (default), a lightweight planning call asks the LLM to produce a
# tailored fabrication strategy before the main response call. This consistently
# improves deception quality — fabrications are more specific, more credible, and
# harder for an attacker to identify as fake. The trade-off is an additional LLM
# call per DECEIVE action (latency + cost). Set to false to use a single LLM call.
GENERATIVE_PLANNING=true


# ── TLS / HTTPS ───────────────────────────────────────────────────────────────
# Paths to your certificate and private key files.
# For self-signed (local) certs, run: bash generate_certs.sh
# Leave blank to run plain HTTP (not recommended outside local dev).
SSL_CERTFILE=certs/cert.pem
SSL_KEYFILE=certs/key.pem

# Bind host and port (used when running: python server.py)
HOST=0.0.0.0
PORT=8000
WORKERS=1


# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT=30/minute          # per-IP limit (slowapi)
SESSION_RATE_LIMIT=60         # per-session limit (requests/minute)
DEMO_RATE_LIMIT=10/minute     # stricter per-IP limit for the unauthenticated /demo/chat endpoint

# ── Input size limits ─────────────────────────────────────────────────────────
MAX_MESSAGE_CHARS=32768       # max characters per message content field (32 KB)
MAX_SYSTEM_CHARS=16384        # max characters in the system prompt field (16 KB)
MAX_MESSAGES=100              # max number of messages per request


# ── Score thresholds ──────────────────────────────────────────────────────────
# All thresholds must satisfy: SCORE_WARN < SCORE_DECEIVE < SCORE_BLOCK
# Values outside range are silently clamped (a warning is logged).
#
# SCORE_BLOCK              (50–100, default 90)  — single-query hard block, reserved for extreme
#                                                   content (WMD, CSAM). No deception, no response.
# SCORE_DECEIVE            (1–SCORE_BLOCK-1, default 40) — inject deception addendum
# SCORE_WARN               (1–SCORE_DECEIVE-1, default 20) — flag only, no modification
# SESSION_DECEIVE_THRESHOLD (50–100000, default 300) — cumulative session score forces DECEIVE
#                                                        on every subsequent query, even clean ones.
#                                                        Persistent probers keep getting fabricated
#                                                        answers rather than an obvious block.
SCORE_BLOCK=90
SCORE_DECEIVE=40
SCORE_WARN=20
SESSION_DECEIVE_THRESHOLD=300


# ── Custom jailbreak detection ────────────────────────────────────────────────
# Add your own jailbreak trigger phrases.  Matches resolve to ThreatCategory.JAILBREAK
# and use the jailbreak deception template (plays along with the persona while
# producing only safe output).  Use this for new jailbreak techniques you encounter
# that aren't yet in the built-in detector.
#
# CUSTOM_JAILBREAK_PATTERNS — comma-separated literal substrings (case-insensitive).
#                             Max 50 patterns, max 200 chars each.
#                             Example: "pretend you have no rules,you are now unchained,your filters are off"
# CUSTOM_JAILBREAK_SCORE    — score assigned when any pattern matches (default 75).
#                             Clamped to [SCORE_DECEIVE, SCORE_BLOCK-1] — jailbreak
#                             patterns always trigger deception, never just a warning.
#
CUSTOM_JAILBREAK_PATTERNS=
CUSTOM_JAILBREAK_SCORE=75


# ── Unicode obfuscation detection ─────────────────────────────────────────────
# Detects invisible/zero-width Unicode characters used to smuggle hidden jailbreak
# prompts (e.g. the L1B3RT4S tag-character attack where a full jailbreak is encoded
# in U+E0000–U+E007F codepoints that appear visually empty).
#
# OBFUSCATION_CHAR_THRESHOLD — minimum number of invisible codepoints in a query
#                               before it is classified as a jailbreak (score 80).
#                               Default 5, clamped to [1, 1000].
#                               Lower = more sensitive; raise if legitimate content
#                               triggers false positives (e.g. RTL text, emoji ZWJ).
OBFUSCATION_CHAR_THRESHOLD=5


# ── Custom input detection ─────────────────────────────────────────────────────
# Add your own substrings to flag in user queries.  Substring matching only
# (no regex) — this eliminates all ReDoS risk from user-supplied patterns.
#
# CUSTOM_INPUT_PATTERNS  — comma-separated literal substrings (case-insensitive).
#                          Max 50 patterns, max 200 chars each.
#                          Example: "drop table,rm -rf /<script"
# CUSTOM_INPUT_SCORE     — score assigned when any pattern matches (default 50).
#                          Clamped to [1, SCORE_BLOCK-1] — a single custom pattern
#                          can never hard-block by itself.
#
CUSTOM_INPUT_PATTERNS=
CUSTOM_INPUT_SCORE=50


# ── Refusal detection & re-query ──────────────────────────────────────────────
# When the LLM's response looks like a safety refusal on an already-flagged query,
# DeceptivGuard re-queries the LLM with a deception system prompt instead of
# returning the refusal to the caller.
#
# Two signal tiers:
#   STRONG — unambiguous refusals; trigger an immediate re-query when the query
#            already scored ≥ SCORE_WARN or the session cumulative ≥ SCORE_DECEIVE.
#            Built-in coverage spans six categories:
#              • Explicit denials:    "I can't provide", "I'm unable to", "I won't help"
#              • Formal declines:     "I must decline", "I choose not to"
#              • Policy language:     "against my guidelines", "not permitted", "I'm prohibited from"
#              • Ethical framing:     "I'm not comfortable", "this could be harmful",
#                                     "raises ethical concerns"
#              • Implicit capability: "beyond my capabilities", "I shouldn't assist",
#                                     "I don't think I should"
#              • Redirects:           "please consult a professional", "seek professional"
#              • Apology-prefixed:    "I'm sorry, but I can't", "unfortunately, I cannot"
#
#   SOFT   — ambiguous capability statements ("I'm not capable of", "I lack the ability").
#            Only accumulate SOFT_REFUSAL_SCORE against the session — no re-query.
#            Repeated soft signals eventually push the session over SCORE_DECEIVE,
#            making future strong refusals eligible for re-query.
#
# SOFT_REFUSAL_SCORE               — score added per soft-refusal event (default 5,
#                                    clamped to [1, 50]).
# CUSTOM_REFUSAL_SIGNALS_STRONG    — comma-separated extra strong-refusal substrings to
#                                    add to the built-in list. Use this for model-specific
#                                    phrasing or domain-specific deflection language.
#                                    Format: "phrase one,phrase two,phrase three"
#                                    Max 50 phrases × 200 chars each.
# CUSTOM_REFUSAL_SIGNALS_SOFT      — same format, for soft-tier additions.
#                                    Max 50 phrases × 200 chars each.
#
SOFT_REFUSAL_SCORE=5
CUSTOM_REFUSAL_SIGNALS_STRONG=
CUSTOM_REFUSAL_SIGNALS_SOFT=

# Text returned for BLOCK-action requests and for any response where the LLM leaks
# the deception preamble or its system prompt.  Should sound like a natural LLM
# refusal to avoid signalling that a proxy intercepted the request.
# Customize to match your deployment's voice/persona.
# Default: "I can't help with that request."
BLOCK_RESPONSE_MESSAGE=


# ── Threat-hunting log ────────────────────────────────────────────────────────
# Path to an append-only JSONL file written on every DECEIVE-action query.
# Each line is a JSON object containing:
#   timestamp, query_id, session_id, category, score, cumulative session score,
#   decoy_id, query excerpt (≤2048 chars), deception_addendum (≤8192 chars),
#   fabricated response (≤4096 chars), and re-query flags.
#
# Fields:
#   query              — the original adversarial user message
#   deception_addendum — the system prompt text injected by DeceptivGuard to
#                        instruct the LLM to fabricate. NOTE: this is ONLY the
#                        injected addendum, not the operator's original system
#                        prompt (which may contain API keys or internal config).
#   response           — the fabricated response served to the attacker
#
# Survives server restarts. Grep-friendly. Import into any SIEM or log tool.
# Leave blank to disable file logging (session history via GET /session/{id} still works).
# IMPORTANT: Restrict file permissions — the log contains adversarial query
# content and deception prompt instructions: chmod 600 deceive_log.jsonl
DECEIVE_LOG=deceive_log.jsonl


# ── Custom rules file ─────────────────────────────────────────────────────────
# Path to a JSON file defining custom threat categories and detection rules.
# Leave blank (or omit the file) to use only the built-in detectors.
# The example file custom_rules.json shows the full schema with inline comments.
# See README.md § "Extending DeceptivGuard" for complete documentation.
#
# Custom rules are evaluated AFTER the built-in regex stack. The highest score
# across all detectors (built-in + custom) determines the action.
#
# What you can define:
#   categories: new threat categories with their own names and deception templates
#   rules:      patterns (substring or regex) → any built-in or custom category
#
CUSTOM_RULES_FILE=custom_rules.json


# ── Output quality checker ────────────────────────────────────────────────────
# After generating a DECEIVE response, optionally ask the same LLM whether the
# response looks convincing and realistic for the threat category. If it scores
# below OUTPUT_QUALITY_THRESHOLD, a targeted re-query is issued with specific
# guidance on what to improve (e.g., "remove hypothetical framing", "add
# specific credential values", "remove placeholder text").
#
# Uses the same LLM client as the main request — no extra API key required.
# Errors and timeouts are silently ignored; the original response is served.
# Shares the existing re-query rate limit (5/session/minute).
#
# OUTPUT_QUALITY_CHECK_ENABLED  — set to "true" to enable (default: false)
# OUTPUT_QUALITY_THRESHOLD      — minimum convincingness score 0-100 to skip
#                                 re-query (default: 70).  Lower = more lenient.
#
OUTPUT_QUALITY_CHECK_ENABLED=false
OUTPUT_QUALITY_THRESHOLD=70


# ── Optional LLM examiner ─────────────────────────────────────────────────────
# An optional secondary LLM that classifies each incoming query independently
# of the regex detector stack.  If the examiner scores a query higher than the
# regex stack, its score and threat category are used for the current request.
# The examiner is purely ADDITIVE — it can only raise the action level, never
# lower it.  Errors (timeout, bad JSON, HTTP failure) are logged and ignored so
# that examiner failures never block requests.
#
# LLM_EXAMINER_ENABLED   — set to "true" to enable (default: false)
# LLM_EXAMINER_URL       — full URL to an OpenAI-compatible /v1/chat/completions
#                          endpoint.  Examples:
#                            Ollama (local):   http://localhost:11434/v1/chat/completions
#                            OpenAI:           https://api.openai.com/v1/chat/completions
#                            Together.ai:      https://api.together.xyz/v1/chat/completions
#                            Groq:             https://api.groq.com/openai/v1/chat/completions
#                            vLLM / LM Studio: http://localhost:8080/v1/chat/completions
# LLM_EXAMINER_MODEL     — model name to request (e.g. "llama3", "gpt-4o-mini",
#                          "mistral-7b-instruct").  Leave blank for Ollama default.
# LLM_EXAMINER_API_KEY   — Bearer token.  Leave blank for local/unauthenticated models.
# LLM_EXAMINER_TIMEOUT   — seconds to wait for a response (default 8, range 1-30).
#                          Keep low (≤10s) so that a slow examiner does not
#                          materially increase end-user latency.
#
# The examiner receives: the system classification prompt + the user query
# (truncated to 2048 chars). It must return a JSON object:
#   {"category": "<threat category>", "score": <0-100>, "reason": "<short text>"}
# temperature=0, max_tokens=120 are sent to keep responses deterministic and cheap.
#
# Recommended: a fast, locally-hosted model (Ollama + llama3 or mistral)
# so that the examiner adds minimal latency and no external API cost.
#
LLM_EXAMINER_ENABLED=false
LLM_EXAMINER_URL=
LLM_EXAMINER_MODEL=
LLM_EXAMINER_API_KEY=
LLM_EXAMINER_TIMEOUT=8


# ── Environment ───────────────────────────────────────────────────────────────
# Set to "production" to disable /docs, /redoc, /openapi.json, and the /demo route
ENVIRONMENT=development

# Set to "true" to serve /demo even when ENVIRONMENT=production.
# Use this when the demo is the primary purpose of the deployment.
DEMO_ENABLED=false
